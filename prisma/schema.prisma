generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  NO_RECORD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee?

  @@map("users")
}

model Employee {
  id            String   @id @default(cuid())
  userId        String   @unique
  employeeCode  String?  @unique
  fullName      String
  position      String?
  dailySalary   Decimal  @default(450.00) @db.Decimal(10, 2)
  lateDeduction Decimal  @default(100.00) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyRecords     DailyRecord[]
  monthlySummaries MonthlySummary[]

  @@map("employees")
}

model DailyRecord {
  id                     String           @id @default(cuid())
  employeeId             String
  workDate               DateTime
  timeIn                 String?
  attendanceStatus       AttendanceStatus @default(PRESENT)
  isLate                 Boolean          @default(false)
  lateDeductionAmount    Decimal          @default(0.00) @db.Decimal(10, 2)
  notes                  String?
  dailyJobIncomeTotal    Decimal          @default(0.00) @db.Decimal(10, 2)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobEntries JobEntry[]

  @@unique([employeeId, workDate])
  @@map("daily_records")
}

model JobEntry {
  id            String   @id @default(cuid())
  dailyRecordId String
  jobType       String
  description   String?
  quantity      Int      @default(1)
  amount        Decimal  @default(0.00) @db.Decimal(10, 2)
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dailyRecord DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)

  @@map("job_entries")
}

model MonthlySummary {
  id                  String   @id @default(cuid())
  employeeId          String
  month               Int
  year                Int
  totalWorkedDays     Int      @default(0)
  totalLateDays       Int      @default(0)
  totalLateDeductions Decimal  @default(0.00) @db.Decimal(10, 2)
  baseSalary          Decimal  @default(0.00) @db.Decimal(10, 2)
  totalJobIncome      Decimal  @default(0.00) @db.Decimal(10, 2)
  bonusAmount         Decimal  @default(0.00) @db.Decimal(10, 2)
  finalSalary         Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("monthly_summaries")
}